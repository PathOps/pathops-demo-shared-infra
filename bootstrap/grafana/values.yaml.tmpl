admin:
  existingSecret: grafana-admin
  userKey: admin-user
  passwordKey: admin-password

service:
  type: ClusterIP

ingress:
  enabled: false

persistence:
  enabled: false

grafana.ini:
  server:
    root_url: https://grafana.demo.pathops.io

  auth:
    disable_login_form: false

  users:
    auto_assign_org: true
    auto_assign_org_role: Viewer

datasources:
  datasources.yaml:
    apiVersion: 1
    datasources:
      - name: Loki
        type: loki
        access: proxy
        url: http://loki-gateway.loki.svc.cluster.local
        isDefault: true