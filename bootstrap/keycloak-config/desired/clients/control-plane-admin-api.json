{
  "clientId": "control-plane-admin-api",
  "name": "PathOps Control Plane Admin API",
  "description": "Confidential machine-to-machine client for administrative operations",
  "enabled": true,
  "protocol": "openid-connect",
  "publicClient": false,
  "bearerOnly": false,
  "standardFlowEnabled": false,
  "implicitFlowEnabled": false,
  "directAccessGrantsEnabled": false,
  "serviceAccountsEnabled": true,
  "clientAuthenticatorType": "client-secret",
  "secret": "${CONTROL_PLANE_ADMIN_API_CLIENT_SECRET}",
  "rootUrl": "${CONTROL_PLANE_BASE_URL}",
  "baseUrl": "${CONTROL_PLANE_BASE_URL}",
  "redirectUris": [],
  "webOrigins": [],
  "defaultClientScopes": [
    "roles"
  ],
  "optionalClientScopes": [
    "microprofile-jwt"
  ]
}